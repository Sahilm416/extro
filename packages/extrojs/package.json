{
  "name": "extrojs",
  "version": "0.3.1",
  "description": "Next.js for Chrome extensions. File-based entrypoints, automatic Manifest V3 generation, and React routing in a single Vite-powered CLI.",
  "keywords": [
    "extro",
    "chrome-extension",
    "browser-extension",
    "manifest-v3",
    "vite",
    "react",
    "framework"
  ],
  "author": "Sahil Mulani <sahilmulani501@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Sahilm416/extro#readme",
  "bugs": {
    "url": "https://github.com/Sahilm416/extro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sahilm416/extro.git",
    "directory": "packages/extrojs"
  },
  "type": "module",
  "main": "./dist/config.js",
  "types": "./dist/config.d.ts",
  "exports": {
    ".": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./asset": {
      "types": "./dist/exports/asset.d.ts",
      "import": "./dist/exports/asset.js"
    },
    "./link": {
      "types": "./dist/exports/link.d.ts",
      "import": "./dist/exports/link.js"
    },
    "./navigation": {
      "types": "./dist/exports/navigation.d.ts",
      "import": "./dist/exports/navigation.js"
    },
    "./runtime": {
      "types": "./dist/exports/runtime.d.ts",
      "import": "./dist/exports/runtime.js"
    },
    "./vite": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    }
  },
  "bin": {
    "extro": "./dist/index.js"
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.runtime.json",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.runtime.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "cac": "^7.0.0",
    "fast-glob": "^3.3.3",
    "jiti": "^2.4.2",
    "picocolors": "^1.1.1",
    "vite": "^8.0.0",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/ws": "^8.18.1"
  }
}
