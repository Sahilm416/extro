{
  "name": "@extro/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for Extro.",
  "keywords": ["extro", "chrome-extension", "manifest-v3", "types"],
  "author": "Sahil Mulani <sahilmulani501@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Sahilm416/extro#readme",
  "bugs": {
