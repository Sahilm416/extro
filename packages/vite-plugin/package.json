{
  "name": "@extrojs/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin powering Extro: file-based entrypoints, Manifest V3 generation, and React routing for Chrome extensions.",
  "keywords": [
    "extro",
    "chrome-extension",
    "manifest-v3",
    "vite",
    "vite-plugin"
  ],
  "author": "Sahil Mulani <sahilmulani501@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Sahilm416/extro#readme",
  "bugs": {
    "url": "https://github.com/Sahilm416/extro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sahilm416/extro.git",
    "directory": "packages/vite-plugin"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@extrojs/react": "workspace:*",
    "vite": "^8"
  },
  "dependencies": {
    "@extrojs/types": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "fast-glob": "^3.3.3"
  }
}
