{
  "name": "@extro/vite-plugin",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@extro/react": "workspace:*",
    "vite": "^8"
  },
  "dependencies": {
    "@extro/types": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "fast-glob": "^3.3.3"
  }
}
