{
  "name": "@extrojs/react",
  "version": "0.1.0",
  "description": "Base React runtime for Extro: ambient env typing for extension surfaces.",
  "keywords": [
    "extro",
    "chrome-extension",
    "manifest-v3",
    "react"
  ],
  "author": "Sahil Mulani <sahilmulani501@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Sahilm416/extro#readme",
  "bugs": {
    "url": "https://github.com/Sahilm416/extro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sahilm416/extro.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "dependencies": {
    "@extrojs/types": "workspace:*"
  }
}
