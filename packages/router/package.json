{
  "name": "@extrojs/router",
  "version": "0.2.0",
  "description": "Hash-based router for Extro: createExtroRouter, Link, useLocation, useParams, useRouter, useSearchParams.",
  "keywords": [
    "extro",
    "chrome-extension",
    "manifest-v3",
    "react",
    "router"
  ],
  "author": "Sahil Mulani <sahilmulani501@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Sahilm416/extro#readme",
  "bugs": {
    "url": "https://github.com/Sahilm416/extro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sahilm416/extro.git",
    "directory": "packages/router"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@extrojs/react": "workspace:^",
    "@extrojs/types": "workspace:^"
  }
}
