# Copy to .env.development / .env.production and fill in.
# Only EXTRO_PUBLIC_* is inlined into surfaces via import.meta.env.

# Public: shipped into every surface bundle (popup, options, sidepanel,
# background, content). Readable by anyone who unpacks the extension.
EXTRO_PUBLIC_GREETING=Hello from Extro
EXTRO_PUBLIC_API_URL=https://api.example.com

# Build-time only: read via process.env by the framework, never inlined.
# EXTRO_CRX_KEY pins a stable extension ID (maps to manifest.key).
# EXTRO_CRX_KEY=MIIBIjANBgkqhki...

# Build-time only: your own private vars are never shipped to a surface.
SECRET_TOKEN=not-shipped-to-any-bundle
